    font-family: var(--font-display);
    font-size: 1.5rem;
    color: #1B3A5C;
    margin: 0 0 0.25rem;
  }

  .module-status {
    font-size: 0.85rem;
    color: var(--color-text-dim);
    margin-bottom: 1rem;
  }

  .module-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 52rem;
    margin-bottom: 1.25rem;
  }

  .module-desc strong {
    color: var(--color-slate);
  }

  .module-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .module-link {
    font-size: 0.95rem;
    color: #1B3A5C;
    text-decoration: none;
    font-weight: 600;
  }

  .module-link:hover {
    color: var(--color-gold);
    text-decoration: underline;
  }

  .module-stats {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-dim);
    margin-bottom: 0.5rem;
  }

  .module-note {
    font-size: 0.85rem;
    color: var(--color-text-dim);
    font-style: italic;
    margin-top: 0.75rem;
    line-height: 1.6;
  }

