    font-weight: 700;
  }

  .compound-formula {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: #64748B;
    margin-top: 0.75rem;
  }

  .compound-planned {
    font-size: 0.85rem;
    color: var(--color-text-dim);
    font-style: italic;
  }

  .compound-closing {
    font-size: 0.95rem;
    color: #94A3B8;
    line-height: 1.8;
    max-width: 52rem;
    margin-top: 2rem;
  }

