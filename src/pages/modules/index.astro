  .building-section {
    padding: 3rem 0 4rem;
  }

  .building-heading {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: #1B3A5C;
    margin-bottom: 1rem;
  }

  .building-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 52rem;
    margin-bottom: 1rem;
  }

  .building-desc a {
    color: #1B3A5C;
  }

  .building-desc a:hover {
    color: var(--color-gold);
    text-decoration: underline;
  }

  /* Filter Tabs */
  .filter-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  .filter-tab {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-dim);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.75rem 1.25rem;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .filter-tab:hover {
    color: var(--color-slate);
  }

  .filter-tab.active {
    color: var(--color-slate);
    font-weight: 600;
    border-bottom-color: var(--color-gold);
  }

  .tab-count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    background: #F3F4F6;
    color: var(--color-text-dim);
    padding: 0.1em 0.45em;
    border-radius: 4px;
  }

  .filter-tab.active .tab-count {
    background: rgba(196, 162, 101, 0.15);
    color: #92400E;
  }

  .module-section[data-status].hidden-by-filter {
    display: none;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .modules-page {
      padding: 0 1rem;
    }

    .modules-hero {
      padding: 2.5rem 0 2rem;
    }

    .hero-title {
      font-size: 2rem;
    }

    .module-title {
      font-size: 1.3rem;
    }

    .module-links {
      flex-direction: column;
      gap: 0.75rem;
    }

    .filter-tabs {
      overflow-x: auto;
    }

    .filter-tab {
      font-size: 0.8rem;
      padding: 0.65rem 0.85rem;
      white-space: nowrap;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.filter-tab');
    const modules = document.querySelectorAll('.module-section[data-status]');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const filter = tab.getAttribute('data-filter');

        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');

        modules.forEach(mod => {
          if (filter === 'all' || mod.getAttribute('data-status') === filter) {
            mod.classList.remove('hidden-by-filter');
            // Re-observe for fade-up if not yet visible
            if (mod.classList.contains('fade-up') && !mod.classList.contains('visible')) {
              const fadeObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                  if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    fadeObserver.unobserve(entry.target);
                  }
                });
              }, { threshold: 0.15 });
              fadeObserver.observe(mod);
            }
          } else {
            mod.classList.add('hidden-by-filter');
          }
        });
      });
    });
  });
</script>
