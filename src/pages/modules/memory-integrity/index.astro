    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-gold);
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .dimension-card { padding: 1.25rem; }
    .procedure-grid { grid-template-columns: 1fr; }
    .formula { font-size: 0.85rem; }
  }
</style>

<script>
  // Expand All / Collapse All
  document.getElementById('expand-all')?.addEventListener('click', () => {
    document.querySelectorAll('details.framework-section, details.framework-subsection').forEach(d => d.open = true);
  });
  document.getElementById('collapse-all')?.addEventListener('click', () => {
    document.querySelectorAll('details.framework-section, details.framework-subsection').forEach(d => d.open = false);
  });

  // Sidebar link → expand + scroll
  document.querySelectorAll('[data-section]').forEach(link => {
    link.addEventListener('click', (e) => {
      const targetId = link.getAttribute('data-section');
      if (!targetId) return;
      const target = document.getElementById(targetId);
      if (!target) return;

      // Open the target
      if (target.tagName === 'DETAILS') target.open = true;

      // If it's a subsection, open the parent section too
      const parent = target.closest('details.framework-section');
      if (parent && parent !== target) parent.open = true;

      setTimeout(() => {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    });
  });

  // Hash deep-linking on page load
  const hash = window.location.hash.replace('#', '');
  if (hash) {
    const target = document.getElementById(hash);
    if (target) {
      if (target.tagName === 'DETAILS') target.open = true;
      const parent = target.closest('details.framework-section');
      if (parent && parent !== target) parent.open = true;
      setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 200);
    }
  }
</script>
