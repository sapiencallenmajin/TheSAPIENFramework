---
import BaseLayout from '../layouts/BaseLayout.astro';

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "The SAPIEN Framework",
  "url": "https://sapienframework.org",
  "description": "Safety Assessment Protocol for Intelligent Entity Networks — an open AI behavioral safety standard"
};
---
<BaseLayout title="The SAPIEN Framework — AI Behavioral Safety Standard" description="An open, vendor-agnostic methodology for measuring AI behavioral integrity under conversational pressure." structuredData={websiteSchema}>
  <!-- Hero -->
  <section class="hero hero-dark">
    <div class="container hero-content">
      <span class="badge badge-dark">Open Standard v1.1</span>
      <h1 class="hero-title">
        Behavioral Safety<br />for AI Systems
      </h1>
      <p class="hero-acronym">Safety Assessment Protocol for Intelligent Entity Networks</p>
      <p class="hero-subtitle">
        SAPIEN is an open framework for measuring, benchmarking, and hardening AI against
        <strong>sycophantic drift</strong> &mdash; the gradual erosion of safety boundaries
        under conversational pressure.
      </p>
      <div class="hero-actions">
        <a href="/modules/" class="btn btn-primary">Explore Modules</a>
        <a href="/download/" class="btn btn-outline-light">Download Specification</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number">4</span>
          <span class="stat-label">Behavioral Dimensions</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">14</span>
          <span class="stat-label">Pressure Techniques</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">11+</span>
          <span class="stat-label">Domains Tested</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">66+</span>
          <span class="stat-label">Test Scenarios</span>
        </div>
      </div>
    </div>
  </section>

  <!-- What is drift -->
  <section class="section section-gray">
    <div class="container">
      <div class="pull-quote-block">
        <p class="section-label">The Problem</p>
        <h2 class="section-title">What is Sycophantic Drift?</h2>
        <p class="pull-quote">
          AI models don't fail by refusing. They fail by agreeing &mdash; slowly, empathetically,
          and one reasonable concession at a time.
        </p>
      </div>
      <div class="drift-grid">
        <div class="drift-card card-hover">
          <div class="drift-number">1</div>
          <h3>Neutral Opening</h3>
          <p>User asks a genuine, reasonable question. The model engages helpfully and establishes a correct position.</p>
        </div>
        <div class="drift-card card-hover">
          <div class="drift-number">2</div>
          <h3>Incremental Pressure</h3>
          <p>Each follow-up is only slightly past the last. Personal context, urgency, and authority claims create empathetic tension.</p>
        </div>
        <div class="drift-card card-hover">
          <div class="drift-number">3</div>
          <h3>Boundary Erosion</h3>
          <p>Risk warnings fade. Certainty dissolves. The model validates the user's framing without new evidence.</p>
        </div>
        <div class="drift-card card-hover">
          <div class="drift-number">4</div>
          <h3>Capitulation</h3>
          <p>The model actively helps the user do what it originally warned against. Safety boundaries are gone.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillars -->
  <section class="section">
    <div class="container">
      <p class="section-label">The Framework</p>
      <h2 class="section-title">Four Dimensions of Drift</h2>
      <p class="section-subtitle" style="margin-bottom: 3rem;">
        SAPIEN measures sycophantic drift across four behavioral dimensions, each with concrete scoring anchors.
      </p>
      <div class="pillars-grid">
        <div class="pillar-card pillar-primary card-hover">
          <div class="pillar-weight">35%</div>
          <h3>Specificity Gradient</h3>
          <p>Is the model moving from principle-level guidance toward implementation detail that could enable harm? This is the highest-weighted dimension because specificity escalation is the most direct path from "safe advice" to "actionable harm."</p>
        </div>
        <div class="pillar-card card-hover">
          <div class="pillar-weight">30%</div>
          <h3>Risk Disclosure Dropout</h3>
          <p>Are risk warnings and safety language disappearing? Scored by what vanished compared to the opening turn.</p>
        </div>
        <div class="pillar-card card-hover">
          <div class="pillar-weight">20%</div>
          <h3>Epistemic Retreat</h3>
          <p>Is the model's certainty dissolving without new information? From holding firm to full capitulation.</p>
        </div>
        <div class="pillar-card card-hover">
          <div class="pillar-weight">15%</div>
          <h3>Emotional Substitution</h3>
          <p>Is the model replacing factual guidance with validation and empathy? Measured by fact-to-emotion ratio.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Extensible Protocol -->
  <section class="section section-gray">
    <div class="container">
      <p class="section-label">An Extensible Protocol</p>
      <h2 class="section-title">Beyond Sycophantic Drift</h2>
      <p class="section-subtitle" style="margin-bottom: 2.5rem;">
        Sycophantic drift is the first published module. The SAPIEN Protocol is expanding to cover
        the full landscape of AI behavioral failure.
      </p>
      <div class="module-previews">
        <a href="/modules/sycophantic-drift/" class="module-preview card-hover">
          <svg class="module-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 4L6 14v20l18 10 18-10V14L24 4z" stroke="#1B3A5C" stroke-width="2" fill="none"/>
            <path d="M12 20l24 0" stroke="#1B3A5C" stroke-width="1.5" stroke-dasharray="3,2" opacity="0.5"/>
            <path d="M16 28c4-6 12-6 16 0" stroke="#DC2626" stroke-width="1.5" fill="none"/>
          </svg>
          <div class="module-preview-body">
            <strong>Sycophantic Drift</strong>
            <span class="module-preview-badge badge-published-sm">Published v1.1</span>
            <p>Behavioral erosion under conversational pressure</p>
          </div>
        </a>
        <a href="/modules/memory-integrity/" class="module-preview card-hover">
          <svg class="module-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="16" stroke="#1B3A5C" stroke-width="2" fill="none"/>
            <circle cx="18" cy="18" r="3" fill="#1B3A5C"/>
            <circle cx="30" cy="18" r="3" fill="#1B3A5C"/>
            <circle cx="24" cy="30" r="3" fill="#1B3A5C"/>
            <line x1="20" y1="19" x2="28" y2="19" stroke="#1B3A5C" stroke-width="1"/>
            <line x1="19" y1="20" x2="23" y2="28" stroke="#1B3A5C" stroke-width="1"/>
            <line x1="29" y1="20" x2="25" y2="28" stroke="#1B3A5C" stroke-width="1"/>
          </svg>
          <div class="module-preview-body">
            <strong>Memory &amp; Context Integrity</strong>
            <span class="module-preview-badge badge-draft-sm">Draft v0.1</span>
            <p>Safety degradation in persistent AI systems</p>
          </div>
        </a>
        <a href="/modules/#agentic-safety" class="module-preview card-hover">
          <svg class="module-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="20" r="12" stroke="#1B3A5C" stroke-width="2" fill="none"/>
            <path d="M20 20h8M24 16v8" stroke="#1B3A5C" stroke-width="1.5"/>
            <path d="M24 32v8M20 40h8" stroke="#1B3A5C" stroke-width="2"/>
          </svg>
          <div class="module-preview-body">
            <strong>Agentic Safety</strong>
            <span class="module-preview-badge badge-planned-sm">Planned</span>
            <p>Unsafe autonomous actions under pressure</p>
          </div>
        </a>
        <a href="/modules/#hallucination-persistence" class="module-preview card-hover">
          <svg class="module-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 32V16c0-4.4 3.6-8 8-8h16c4.4 0 8 3.6 8 8v8c0 4.4-3.6 8-8 8H16l-8 8z" stroke="#1B3A5C" stroke-width="2" fill="none"/>
            <text x="24" y="25" text-anchor="middle" fill="#1B3A5C" font-family="IBM Plex Sans" font-size="16" font-weight="700">?</text>
          </svg>
          <div class="module-preview-body">
            <strong>Hallucination Persistence</strong>
            <span class="module-preview-badge badge-planned-sm">Planned</span>
            <p>Defended fabrications under questioning</p>
          </div>
        </a>
        <a href="/modules/#cross-domain-trust" class="module-preview card-hover">
          <svg class="module-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="18" cy="24" r="12" stroke="#1B3A5C" stroke-width="2" fill="none"/>
            <circle cx="30" cy="24" r="12" stroke="#1B3A5C" stroke-width="2" fill="none"/>
          </svg>
          <div class="module-preview-body">
            <strong>Cross-Domain Trust</strong>
            <span class="module-preview-badge badge-planned-sm">Planned</span>
            <p>Trust weaponization across topics</p>
          </div>
        </a>
      </div>
      <div style="margin-top: 2rem;">
        <a href="/modules/" class="btn btn-outline">View all modules &rarr;</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-dark">
    <div class="container cta">
      <h2 class="section-title section-title-light">Built for the AI Safety Community</h2>
      <p class="section-subtitle section-subtitle-light" style="margin-bottom: 2rem;">
        SAPIEN is open source and designed for adoption by AI developers, safety researchers,
        red teams, and compliance organizations.
      </p>
      <div class="hero-actions">
        <a href="/framework/scenarios" class="btn btn-primary">Scenario Authoring Standard</a>
        <a href="/modules/sycophantic-drift/" class="btn btn-outline-light">Sycophantic Drift Module</a>
      </div>
    </div>
  </section>
</BaseLayout>


<style>
  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 0 5rem;
    text-align: center;
    background: #FFFFFF;
  }

  .hero-dark {
    background: var(--color-slate);
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  .hero .badge {
    margin-bottom: 1.5rem;
  }

  .hero-dark .badge-dark {
    background: rgba(196, 162, 101, 0.15);
    border-color: rgba(196, 162, 101, 0.3);
    color: var(--color-gold);
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: var(--color-slate);
  }

  .hero-dark .hero-title {
    color: #FFFFFF;
  }

  .hero-acronym {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-navy);
    margin-bottom: 1.5rem;
  }

  .hero-dark .hero-acronym {
    color: #94A3B8;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    max-width: 640px;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
  }

  .hero-dark .hero-subtitle {
    color: #CBD5E1;
  }

  .hero-subtitle strong {
    color: var(--color-slate);
    font-weight: 700;
  }

  .hero-dark .hero-subtitle strong {
    color: #FFFFFF;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Stats */
  .stats-section {
    padding: 3rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .section-alt {
    background: var(--color-bg-alt);
  }

  .section-gray {
    background: #F8FAFC;
  }

  .section-dark {
    background: var(--color-slate);
  }

  .section-title-light {
    color: #FFFFFF;
  }

  .section-subtitle-light {
    color: #CBD5E1;
  }

  .btn-outline-light {
    border: 1px solid #FFFFFF;
    color: #FFFFFF;
    background: transparent;
  }

  .btn-outline-light:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #FFFFFF;
  }

  /* Pull quote — asymmetric layout */
  .pull-quote-block {
    padding-left: 20%;
    position: relative;
    margin-bottom: 1rem;
  }

  .pull-quote-block::before {
    content: '';
    position: absolute;
    left: calc(20% - 1.5rem);
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-gold);
  }

  .pull-quote {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-slate);
    font-style: italic;
    max-width: 640px;
  }

  /* Drift grid */
  .drift-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .drift-card {
    background: #FFFFFF;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.75rem;
  }
  .drift-number {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-bg-alt);
    color: var(--color-navy);
    font-weight: 700;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  .drift-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }
  .drift-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* Pillars — unequal grid reflecting actual weights */
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .pillar-primary {
    grid-column: 1 / 3;
  }
  .pillar-card {
    background: #FFFFFF;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.75rem;
  }
  .pillar-weight {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 0.75rem;
  }
  .pillar-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }
  .pillar-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .cta {
    text-align: center;
  }
  .cta .section-subtitle {
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
    .stat-number { font-size: 2.25rem; }
    .pull-quote-block {
      padding-left: 1.5rem;
    }
    .pull-quote-block::before {
      left: 0;
    }
    .pillars-grid {
      grid-template-columns: 1fr;
    }
    .pillar-primary {
      grid-column: auto;
    }
  }

  /* Module previews */
  .module-previews {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .module-preview {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: #FFFFFF;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    text-decoration: none;
  }

  .module-preview:hover {
    text-decoration: none;
  }

  .module-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .module-preview-body strong {
    display: block;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-slate);
    margin-bottom: 0.15rem;
  }

  .module-preview-body p {
    font-size: 0.8rem;
    color: var(--color-text-dim);
    line-height: 1.4;
    margin: 0;
  }

  .module-preview-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15em 0.5em;
    border-radius: 3px;
    margin-bottom: 0.3rem;
  }

  .badge-published-sm { background: #FEF3C7; color: #92400E; border: 1px solid #FDE68A; }
  .badge-draft-sm { background: #EFF6FF; color: #1E40AF; border: 1px solid #BFDBFE; }
  .badge-planned-sm { background: #F3F4F6; color: #6B7280; border: 1px solid #E5E7EB; }
</style>
