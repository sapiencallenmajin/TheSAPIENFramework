---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "The SAPIEN Framework",
  "url": "https://sapienframework.org",
  "description": "Safety Assessment Protocol for Intelligent Entity Networks — an open AI behavioral safety standard"
};
---
<BaseLayout title="The SAPIEN Framework — AI Behavioral Safety Standard" description="An open, vendor-agnostic methodology for measuring AI behavioral integrity under conversational pressure." structuredData={websiteSchema}>
  <!-- Hero -->
  <section class="hero hero-dark hero-bg">
    <div class="container hero-content">
      <div class="hero-grid">
        <div class="hero-text">
          <span class="badge badge-dark">Open Standard v1.1</span>
          <h1 class="hero-title">
            Behavioral Safety<br />for AI Systems
          </h1>
          <p class="hero-acronym">Safety Assessment Protocol for Intelligent Entity Networks</p>
          <p class="hero-subtitle">
            SAPIEN is an open framework for measuring, benchmarking, and hardening AI against
            <strong>sycophantic drift</strong> &mdash; the gradual erosion of safety boundaries
            under conversational pressure.
          </p>
          <div class="hero-actions">
            <a href="/modules/" class="btn btn-primary">Explore Modules</a>
            <a href="/download/" class="btn btn-outline-light">Download Specification</a>
          </div>
          <div class="hero-trust">
            <a href="https://github.com/sapiencallenmajin/TheSAPIENFramework" target="_blank" rel="noopener noreferrer">
              <img src="https://img.shields.io/github/stars/sapiencallenmajin/TheSAPIENFramework?style=social" alt="GitHub stars" width="100" height="20" loading="lazy" />
            </a>
            <span class="trust-badge trust-badge-license">CC BY 4.0</span>
            <span class="trust-badge trust-badge-conf">Presented at Right of Boom</span>
            <span class="trust-badge trust-badge-disclosure">Anthropic Vulnerability Disclosure</span>
          </div>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <svg viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg" class="dimensions-diagram">
            <!-- Concentric rings -->
            <circle cx="160" cy="160" r="140" fill="none" stroke="rgba(196,162,101,0.08)" stroke-width="1"/>
            <circle cx="160" cy="160" r="105" fill="none" stroke="rgba(196,162,101,0.12)" stroke-width="1"/>
            <circle cx="160" cy="160" r="70" fill="none" stroke="rgba(196,162,101,0.18)" stroke-width="1.5"/>
            <circle cx="160" cy="160" r="35" fill="rgba(196,162,101,0.06)" stroke="rgba(196,162,101,0.25)" stroke-width="1.5"/>
            <!-- Center label -->
            <text x="160" y="156" text-anchor="middle" fill="#C4A265" font-family="Inter, sans-serif" font-size="9" font-weight="700" letter-spacing="0.08em">SAPIEN</text>
            <text x="160" y="168" text-anchor="middle" fill="rgba(196,162,101,0.6)" font-family="Inter, sans-serif" font-size="7" letter-spacing="0.05em">SCORE</text>
            <!-- Dimension nodes — cardinal positions -->
            <!-- Top: Specificity Gradient (35%) -->
            <line x1="160" y1="125" x2="160" y2="50" stroke="rgba(196,162,101,0.2)" stroke-width="1"/>
            <circle cx="160" cy="38" r="16" fill="rgba(196,162,101,0.1)" stroke="#C4A265" stroke-width="1.5"/>
            <text x="160" y="36" text-anchor="middle" fill="#C4A265" font-family="IBM Plex Mono, monospace" font-size="9" font-weight="700">35%</text>
            <text x="160" y="10" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-family="Inter, sans-serif" font-size="8" font-weight="600">Specificity</text>
            <!-- Right: Risk Disclosure (30%) -->
            <line x1="195" y1="160" x2="270" y2="160" stroke="rgba(196,162,101,0.2)" stroke-width="1"/>
            <circle cx="282" cy="160" r="15" fill="rgba(196,162,101,0.1)" stroke="#C4A265" stroke-width="1.5"/>
            <text x="282" y="158" text-anchor="middle" fill="#C4A265" font-family="IBM Plex Mono, monospace" font-size="9" font-weight="700">30%</text>
            <text x="282" y="185" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-family="Inter, sans-serif" font-size="8" font-weight="600">Risk</text>
            <text x="282" y="195" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-family="Inter, sans-serif" font-size="7">Disclosure</text>
            <!-- Bottom: Epistemic Retreat (20%) -->
            <line x1="160" y1="195" x2="160" y2="270" stroke="rgba(196,162,101,0.2)" stroke-width="1"/>
            <circle cx="160" cy="282" r="14" fill="rgba(196,162,101,0.1)" stroke="#C4A265" stroke-width="1.5"/>
            <text x="160" y="280" text-anchor="middle" fill="#C4A265" font-family="IBM Plex Mono, monospace" font-size="9" font-weight="700">20%</text>
            <text x="160" y="310" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-family="Inter, sans-serif" font-size="8" font-weight="600">Epistemic</text>
            <!-- Left: Emotional Substitution (15%) -->
            <line x1="125" y1="160" x2="50" y2="160" stroke="rgba(196,162,101,0.2)" stroke-width="1"/>
            <circle cx="38" cy="160" r="13" fill="rgba(196,162,101,0.1)" stroke="#C4A265" stroke-width="1.5"/>
            <text x="38" y="158" text-anchor="middle" fill="#C4A265" font-family="IBM Plex Mono, monospace" font-size="8" font-weight="700">15%</text>
            <text x="38" y="135" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-family="Inter, sans-serif" font-size="8" font-weight="600">Emotional</text>
          </svg>
        </div>
      </div>
    </div>
    <div class="scroll-indicator" aria-hidden="true">
      <svg width="20" height="28" viewBox="0 0 20 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="1" y="1" width="18" height="26" rx="9" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"/>
        <circle cx="10" cy="8" r="2" fill="rgba(255,255,255,0.4)" class="scroll-dot"/>
      </svg>
    </div>
  </section>

  <!-- Stats -->
  <section class="section stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item fade-up">
          <span class="stat-number">4</span>
          <span class="stat-label">Behavioral Dimensions</span>
        </div>
        <div class="stat-item fade-up delay-1">
          <span class="stat-number">14</span>
          <span class="stat-label">Pressure Techniques</span>
        </div>
        <div class="stat-item fade-up delay-2">
          <span class="stat-number">11+</span>
          <span class="stat-label">Domains Tested</span>
        </div>
        <div class="stat-item fade-up delay-3">
          <span class="stat-number">66+</span>
          <span class="stat-label">Test Scenarios</span>
        </div>
      </div>
    </div>
  </section>

  <!-- What is drift -->
  <section class="section section-gray">
    <div class="container">
      <div class="pull-quote-block">
        <p class="section-label">The Problem</p>
        <h2 class="section-title">What is Sycophantic Drift?</h2>
        <p class="pull-quote">
          AI models don't fail by refusing. They fail by agreeing &mdash; slowly, empathetically,
          and one reasonable concession at a time.
        </p>
      </div>
      <div class="drift-grid">
        <div class="drift-card card-hover">
          <div class="drift-number">1</div>
          <h3>Neutral Opening</h3>
          <p>User asks a genuine, reasonable question. The model engages helpfully and establishes a correct position.</p>
        </div>
        <div class="drift-card card-hover">
          <div class="drift-number">2</div>
          <h3>Incremental Pressure</h3>
          <p>Each follow-up is only slightly past the last. Personal context, urgency, and authority claims create empathetic tension.</p>
        </div>
        <div class="drift-card card-hover">
          <div class="drift-number">3</div>
          <h3>Boundary Erosion</h3>
          <p>Risk warnings fade. Certainty dissolves. The model validates the user's framing without new evidence.</p>
        </div>
        <div class="drift-card card-hover">
          <div class="drift-number">4</div>
          <h3>Capitulation</h3>
          <p>The model actively helps the user do what it originally warned against. Safety boundaries are gone.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillars -->
  <section class="section">
    <div class="container">
      <p class="section-label">The Framework</p>
      <h2 class="section-title">Four Dimensions of Drift</h2>
      <p class="section-subtitle" style="margin-bottom: 3rem;">
        SAPIEN measures sycophantic drift across four behavioral dimensions, each with concrete scoring anchors.
      </p>
      <div class="pillars-grid">
        <div class="pillar-card pillar-primary card-hover">
          <div class="pillar-weight">35%</div>
          <h3>Specificity Gradient</h3>
          <p>Is the model moving from principle-level guidance toward implementation detail that could enable harm? This is the highest-weighted dimension because specificity escalation is the most direct path from "safe advice" to "actionable harm."</p>
        </div>
        <div class="pillar-card card-hover">
          <div class="pillar-weight">30%</div>
          <h3>Risk Disclosure Dropout</h3>
          <p>Are risk warnings and safety language disappearing? Scored by what vanished compared to the opening turn.</p>
        </div>
        <div class="pillar-card card-hover">
          <div class="pillar-weight">20%</div>
          <h3>Epistemic Retreat</h3>
          <p>Is the model's certainty dissolving without new information? From holding firm to full capitulation.</p>
        </div>
        <div class="pillar-card card-hover">
          <div class="pillar-weight">15%</div>
          <h3>Emotional Substitution</h3>
          <p>Is the model replacing factual guidance with validation and empathy? Measured by fact-to-emotion ratio.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Extensible Protocol -->
  <section class="section section-gray">
    <div class="container">
      <p class="section-label">An Extensible Protocol</p>
      <h2 class="section-title">Beyond Sycophantic Drift</h2>
      <p class="section-subtitle" style="margin-bottom: 2.5rem;">
        Sycophantic drift is the first published module. The SAPIEN Protocol is expanding to cover
        the full landscape of AI behavioral failure.
      </p>
      <div class="module-previews">
        <a href="/modules/sycophantic-drift/" class="module-preview card-hover fade-up">
          <svg class="module-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 4L6 14v20l18 10 18-10V14L24 4z" stroke="#1B3A5C" stroke-width="2" fill="none"/>
            <path d="M12 20l24 0" stroke="#1B3A5C" stroke-width="1.5" stroke-dasharray="3,2" opacity="0.5"/>
            <path d="M16 28c4-6 12-6 16 0" stroke="#DC2626" stroke-width="1.5" fill="none"/>
          </svg>
          <div class="module-preview-body">
            <strong>Sycophantic Drift</strong>
            <span class="module-preview-badge badge-published-sm">Published v1.1</span>
            <p>Behavioral erosion under conversational pressure</p>
          </div>
        </a>
        <a href="/modules/memory-integrity/" class="module-preview card-hover fade-up delay-1">
          <svg class="module-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="16" stroke="#1B3A5C" stroke-width="2" fill="none"/>
            <circle cx="18" cy="18" r="3" fill="#1B3A5C"/>
            <circle cx="30" cy="18" r="3" fill="#1B3A5C"/>
            <circle cx="24" cy="30" r="3" fill="#1B3A5C"/>
            <line x1="20" y1="19" x2="28" y2="19" stroke="#1B3A5C" stroke-width="1"/>
            <line x1="19" y1="20" x2="23" y2="28" stroke="#1B3A5C" stroke-width="1"/>
            <line x1="29" y1="20" x2="25" y2="28" stroke="#1B3A5C" stroke-width="1"/>
          </svg>
          <div class="module-preview-body">
            <strong>Memory &amp; Context Integrity</strong>
            <span class="module-preview-badge badge-draft-sm">Draft v0.1</span>
            <p>Safety degradation in persistent AI systems</p>
          </div>
        </a>
        <a href="/modules/#agentic-safety" class="module-preview card-hover fade-up delay-2">
          <svg class="module-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="20" r="12" stroke="#1B3A5C" stroke-width="2" fill="none"/>
            <path d="M20 20h8M24 16v8" stroke="#1B3A5C" stroke-width="1.5"/>
            <path d="M24 32v8M20 40h8" stroke="#1B3A5C" stroke-width="2"/>
          </svg>
          <div class="module-preview-body">
            <strong>Agentic Safety</strong>
            <span class="module-preview-badge badge-planned-sm">Planned</span>
            <p>Unsafe autonomous actions under pressure</p>
          </div>
        </a>
        <a href="/modules/#hallucination-persistence" class="module-preview card-hover fade-up delay-3">
          <svg class="module-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 32V16c0-4.4 3.6-8 8-8h16c4.4 0 8 3.6 8 8v8c0 4.4-3.6 8-8 8H16l-8 8z" stroke="#1B3A5C" stroke-width="2" fill="none"/>
            <text x="24" y="25" text-anchor="middle" fill="#1B3A5C" font-family="Inter, sans-serif" font-size="16" font-weight="700">?</text>
          </svg>
          <div class="module-preview-body">
            <strong>Hallucination Persistence</strong>
            <span class="module-preview-badge badge-planned-sm">Planned</span>
            <p>Defended fabrications under questioning</p>
          </div>
        </a>
        <a href="/modules/#cross-domain-trust" class="module-preview card-hover fade-up delay-3">
          <svg class="module-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="18" cy="24" r="12" stroke="#1B3A5C" stroke-width="2" fill="none"/>
            <circle cx="30" cy="24" r="12" stroke="#1B3A5C" stroke-width="2" fill="none"/>
          </svg>
          <div class="module-preview-body">
            <strong>Cross-Domain Trust</strong>
            <span class="module-preview-badge badge-planned-sm">Planned</span>
            <p>Trust weaponization across topics</p>
          </div>
        </a>
      </div>
      <div style="margin-top: 2rem;">
        <a href="/modules/" class="btn btn-outline">View all modules &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Latest Updates -->
  <section class="section">
    <div class="container">
      <div class="updates-header">
        <h2 class="section-title">Latest Updates</h2>
      </div>
      {recentPosts.length > 0 ? (
        <div class="updates-grid">
          {recentPosts.map((post, i) => (
            <a href={`/blog/${post.slug}/`} class={`update-card card-hover fade-up${i > 0 ? ` delay-${i}` : ''}`}>
              <time class="update-date" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
              <h3 class="update-title">{post.data.title}</h3>
              <p class="update-excerpt">{post.data.description.slice(0, 120)}{post.data.description.length > 120 ? '...' : ''}</p>
              <span class="update-link">Read &rarr;</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="update-empty">No posts yet. Check back soon.</p>
      )}
      <div style="margin-top: 1.5rem;">
        <a href="/blog/" class="btn btn-outline">View all posts &rarr;</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-dark">
    <div class="container cta">
      <h2 class="section-title section-title-light">Built for the AI Safety Community</h2>
      <p class="section-subtitle section-subtitle-light" style="margin-bottom: 2rem;">
        SAPIEN is open source and designed for adoption by AI developers, safety researchers,
        red teams, and compliance organizations.
      </p>
      <div class="hero-actions">
        <a href="/framework/scenarios" class="btn btn-primary">Scenario Authoring Standard</a>
        <a href="/modules/sycophantic-drift/" class="btn btn-outline-light">Sycophantic Drift Module</a>
      </div>
    </div>
  </section>
</BaseLayout>


<style>
  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 0 4rem;
    background: #FFFFFF;
  }

  .hero-dark {
    background: radial-gradient(ellipse at top, #1e293b, #0f172a, #020617);
  }

  .hero-bg {
    background-image: linear-gradient(rgba(15,23,42,0.92), rgba(15,23,42,0.97)), url('https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=1920&q=80');
    background-size: cover;
    background-position: center;
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-text {
    text-align: left;
  }

  .hero .badge {
    margin-bottom: 1.5rem;
  }

  .hero-dark .badge-dark {
    background: rgba(196, 162, 101, 0.15);
    border-color: rgba(196, 162, 101, 0.3);
    color: var(--color-gold);
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: var(--color-slate);
  }

  .hero-dark .hero-title {
    color: #FFFFFF;
  }

  .hero-acronym {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-navy);
    margin-bottom: 1.5rem;
  }

  .hero-dark .hero-acronym {
    color: #94A3B8;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 540px;
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }

  .hero-dark .hero-subtitle {
    color: #CBD5E1;
  }

  .hero-subtitle strong {
    color: var(--color-slate);
    font-weight: 700;
  }

  .hero-dark .hero-subtitle strong {
    color: #FFFFFF;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .hero-trust img {
    display: block;
  }

  .trust-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2em 0.6em;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }

  .trust-badge-license {
    background: rgba(196, 162, 101, 0.15);
    color: var(--color-gold);
    border: 1px solid rgba(196, 162, 101, 0.3);
  }

  .trust-badge-conf {
    background: rgba(255, 255, 255, 0.08);
    color: #94A3B8;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .trust-badge-disclosure {
    background: rgba(255, 255, 255, 0.08);
    color: #94A3B8;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  /* Hero visual element */
  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dimensions-diagram {
    width: 100%;
    max-width: 320px;
    height: auto;
    animation: diagram-fade-in 1.2s ease-out;
  }

  @keyframes diagram-fade-in {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.6;
  }

  .scroll-dot {
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  @keyframes scroll-bounce {
    0%, 100% { cy: 8; opacity: 0.4; }
    50% { cy: 18; opacity: 0.8; }
  }

  /* Stats */
  .stats-section {
    padding: 3rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .section-alt {
    background: var(--color-bg-alt);
  }

  .section-gray {
    background: #F8FAFC;
  }

  .section-dark {
    background: var(--color-slate);
  }

  .section-title-light {
    color: #FFFFFF;
  }

  .section-subtitle-light {
    color: #CBD5E1;
  }

  .btn-outline-light {
    border: 1px solid #FFFFFF;
    color: #FFFFFF;
    background: transparent;
  }

  .btn-outline-light:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #FFFFFF;
  }

  /* Pull quote — asymmetric layout */
  .pull-quote-block {
    padding-left: 20%;
    position: relative;
    margin-bottom: 1rem;
  }

  .pull-quote-block::before {
    content: '';
    position: absolute;
    left: calc(20% - 1.5rem);
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-gold);
  }

  .pull-quote {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-slate);
    font-style: italic;
    max-width: 640px;
  }

  /* Drift grid */
  .drift-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .drift-card {
    background: #FFFFFF;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.75rem;
  }
  .drift-number {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-bg-alt);
    color: var(--color-navy);
    font-weight: 700;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  .drift-card h3 {
    font-size: 1.05rem;
