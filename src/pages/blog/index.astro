---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="SAPIEN Framework Blog" description="Updates, research notes, and announcements from the SAPIEN Behavioral Safety Framework.">

  <div class="blog-page">

    <header class="blog-hero">
      <h1 class="blog-title">Blog</h1>
      <p class="blog-subtitle">Updates, research notes, and announcements</p>
    </header>

    <div class="post-list">
      {posts.map(post => (
        <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="post-card">
          <div class="post-card-inner">
            <h2 class="post-card-title">{post.data.title}</h2>
            <time class="post-card-date" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <p class="post-card-desc">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>

  </div>

</BaseLayout>

<style>
  .blog-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .blog-hero {
    text-align: center;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .blog-title {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--color-slate);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .blog-subtitle {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Post List */
  .post-list {
    display: flex;
    flex-direction: column;
  }

  .post-card {
    display: block;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
  }

  .post-card:first-child {
    padding-top: 0;
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-card:hover .post-card-title {
    color: var(--color-navy);
  }

  .post-card-inner {
    padding: 0 0.5rem;
  }

  .post-card-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--color-slate);
    line-height: 1.3;
    margin-bottom: 0.4rem;
    transition: color 0.2s;
  }

  .post-card-date {
    display: block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-text-dim);
    margin-bottom: 0.6rem;
  }

  .post-card-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .blog-title { font-size: 2.25rem; }
  }
</style>
