---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = posts[0];
const remaining = posts.slice(1);

function estimateReadTime(body: string): string {
  const words = body.split(/\s+/).length;
  const minutes = Math.max(1, Math.ceil(words / 230));
  return `${minutes} min read`;
}

const tagColors: Record<string, { bg: string; text: string; border: string }> = {
  release:     { bg: '#FEF3C7', text: '#92400E', border: '#FDE68A' },
  framework:   { bg: '#EFF6FF', text: '#1E40AF', border: '#BFDBFE' },
  msp:         { bg: '#F0FDF4', text: '#166534', border: '#BBF7D0' },
  sycophancy:  { bg: '#FFF1F2', text: '#9F1239', border: '#FECDD3' },
  safety:      { bg: '#F3F4F6', text: '#4B5563', border: '#E5E7EB' },
};

function getTagStyle(tag: string) {
  return tagColors[tag] || { bg: '#F3F4F6', text: '#4B5563', border: '#E5E7EB' };
}
---
<BaseLayout title="SAPIEN Framework Blog" description="Updates, research notes, and announcements from the SAPIEN Behavioral Safety Framework.">

  <div class="blog-page">

    <header class="blog-hero">
      <div class="blog-hero-left">
        <h1 class="blog-title">Blog</h1>
        <p class="blog-subtitle">Updates, research notes, and announcements</p>
      </div>
      <a href="/blog/rss.xml" class="rss-link" title="RSS Feed">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="6.5" cy="17.5" r="2.5" fill="currentColor"/>
          <path d="M4 4a16 16 0 0116 16" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"/>
          <path d="M4 11a9 9 0 019 9" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        </svg>
        RSS
      </a>
    </header>

    {/* Featured post */}
    {featured && (
      <a href={`/blog/${featured.id.replace(/\.md$/, '')}/`} class="featured-card">
        <div class="featured-inner">
          <div class="featured-meta">
            <time datetime={featured.data.date.toISOString()}>
              {featured.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span class="meta-sep">&middot;</span>
            <span>{estimateReadTime(featured.body ?? featured.data.description)}</span>
          </div>
          {featured.data.tags && (
            <div class="tag-row">
              {featured.data.tags.map((tag: string) => {
                const s = getTagStyle(tag);
                return <span class="tag-pill" style={`background:${s.bg};color:${s.text};border:1px solid ${s.border}`}>{tag}</span>;
              })}
            </div>
          )}
          <h2 class="featured-title">{featured.data.title}</h2>
          <p class="featured-desc">{featured.data.description}</p>
          <span class="featured-read">Read &rarr;</span>
        </div>
      </a>
    )}

    {/* Remaining posts */}
    {remaining.length > 0 && (
      <div class="post-list">
        {remaining.map(post => (
          <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="post-row fade-up">
            <div class="post-row-date">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
              </time>
              <span class="post-row-year">{post.data.date.getFullYear()}</span>
            </div>
            <div class="post-row-body">
              {post.data.tags && (
                <div class="tag-row tag-row-sm">
                  {post.data.tags.map((tag: string) => {
                    const s = getTagStyle(tag);
                    return <span class="tag-pill tag-pill-sm" style={`background:${s.bg};color:${s.text};border:1px solid ${s.border}`}>{tag}</span>;
                  })}
                </div>
              )}
              <h3 class="post-row-title">{post.data.title}</h3>
              <p class="post-row-desc">{post.data.description}</p>
            </div>
            <span class="post-row-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    )}

    {/* Subscribe CTA */}
    <div class="subscribe-card">
      <h3>Stay updated on AI behavioral safety research</h3>
      <p>Watch the repository for release notifications, new modules, and research findings.</p>
      <a href="https://github.com/sapiencallenmajin/TheSAPIENFramework" target="_blank" rel="noopener noreferrer" class="btn btn-outline">
        Watch on GitHub &nearr;
      </a>
    </div>

  </div>

</BaseLayout>

<style>
  .blog-page {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  /* Hero */
  .blog-hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .blog-title {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--color-slate);
    line-height: 1.2;
    margin-bottom: 0.35rem;
  }

  .blog-subtitle {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .rss-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-dim);
    text-decoration: none;
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: all 0.15s;
  }

  .rss-link:hover {
    color: var(--color-gold);
    border-color: var(--color-gold);
  }

  /* Featured post */
  .featured-card {
    display: block;
    background: #F8FAFC;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: border-color 0.2s;
  }

  .featured-card:hover {
    border-color: var(--color-navy);
    text-decoration: none;
  }

  .featured-inner {
    padding: 2rem;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-text-dim);
    margin-bottom: 0.75rem;
  }

  .meta-sep { color: var(--color-border); }

  .featured-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-slate);
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .featured-card:hover .featured-title {
    color: var(--color-navy);
  }

  .featured-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .featured-read {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-navy);
  }

  .featured-card:hover .featured-read {
    color: var(--color-gold);
  }

  /* Tags */
  .tag-row {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .tag-row-sm { margin-bottom: 0.25rem; }

  .tag-pill {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.15em 0.55em;
    border-radius: 4px;
  }

  .tag-pill-sm { font-size: 0.6rem; }

  /* Post list — single column rows */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 3rem;
  }

  .post-row {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: background 0.15s;
  }

  .post-row:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-row:hover {
    text-decoration: none;
  }

  .post-row-date {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    min-width: 4rem;
    flex-shrink: 0;
    padding-top: 0.15rem;
  }

  .post-row-date time {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-navy);
    line-height: 1.2;
  }

  .post-row-year {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-dim);
  }

  .post-row-body {
    flex: 1;
    min-width: 0;
  }

  .post-row-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-slate);
    line-height: 1.35;
    margin-bottom: 0.35rem;
    transition: color 0.2s;
  }

  .post-row:hover .post-row-title {
    color: var(--color-navy);
  }

  .post-row-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-row-arrow {
    font-size: 1rem;
    color: var(--color-text-dim);
    flex-shrink: 0;
    padding-top: 0.2rem;
    transition: color 0.15s;
  }

  .post-row:hover .post-row-arrow {
    color: var(--color-gold);
  }

  /* Subscribe CTA */
  .subscribe-card {
    background: #F8FAFC;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
  }

  .subscribe-card h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-slate);
    margin-bottom: 0.5rem;
  }

  .subscribe-card p {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .blog-title { font-size: 2.25rem; }
    .featured-title { font-size: 1.35rem; }
    .featured-inner { padding: 1.5rem; }
    .post-row-date { min-width: 3.5rem; }
    .post-row-date time { font-size: 0.75rem; }
  }

  @media (max-width: 480px) {
    .blog-hero { flex-direction: column; align-items: flex-start; gap: 1rem; }
  }
</style>
