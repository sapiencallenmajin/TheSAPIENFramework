---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(post => !post.data.draft);
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---
<BaseLayout title={post.data.title} description={post.data.description}>

  <article class="blog-post">

    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="meta-sep">&middot;</span>
        <span>{post.data.author}</span>
      </div>
      {post.data.tags && (
        <div class="post-tags">
          {post.data.tags.map(tag => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/blog/" class="back-link">&larr; Back to Blog</a>
    </footer>

  </article>

</BaseLayout>

<style>
  .blog-post {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  /* Header */
  .post-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 2px solid color-mix(in srgb, var(--color-gold) 30%, transparent);
    margin-bottom: 2.5rem;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--color-gold);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .post-meta {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--color-cream) 55%, transparent);
    margin-bottom: 0.75rem;
  }

  .meta-sep {
    margin: 0 0.5rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag-pill {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gold);
    background: color-mix(in srgb, var(--color-gold) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-gold) 20%, transparent);
    padding: 0.2em 0.6em;
    border-radius: 3px;
  }

  /* Prose Content */
  .post-content {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.8;
    color: color-mix(in srgb, var(--color-cream) 90%, transparent);
  }

  .post-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--color-gold);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-gold);
    margin-top: 2rem;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .post-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-content :global(strong) {
    color: var(--color-cream);
    font-weight: 700;
  }

  .post-content :global(em) {
    color: var(--color-cream);
    font-style: italic;
  }

  .post-content :global(a) {
    color: var(--color-gold);
    text-decoration: none;
  }

  .post-content :global(a:hover) {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .post-content :global(ul) {
    list-style: none;
  }

  .post-content :global(ul li) {
    position: relative;
    padding-left: 1rem;
    margin-bottom: 0.4rem;
  }

  .post-content :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-gold);
  }

  .post-content :global(ol li) {
    margin-bottom: 0.4rem;
  }

  .post-content :global(ol li::marker) {
    color: var(--color-gold);
    font-weight: 600;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-gold);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: color-mix(in srgb, var(--color-gold) 6%, transparent);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: var(--color-cream);
  }

  .post-content :global(blockquote p) {
    margin-bottom: 0;
  }

  .post-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    background: color-mix(in srgb, var(--color-navy) 40%, transparent);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--color-cream);
  }

  .post-content :global(pre) {
    background: color-mix(in srgb, var(--color-navy) 40%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-gold) 12%, transparent);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid color-mix(in srgb, var(--color-gold) 15%, transparent);
    margin: 2rem 0;
  }

  /* Footer */
  .post-footer {
    padding-top: 2.5rem;
    margin-top: 2.5rem;
    border-top: 1px solid color-mix(in srgb, var(--color-gold) 15%, transparent);
  }

  .back-link {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-gold);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-cream);
  }

  @media (max-width: 768px) {
    .post-title { font-size: 1.85rem; }
  }
</style>
