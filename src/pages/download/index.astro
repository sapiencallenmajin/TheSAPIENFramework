---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Download the SAPIEN Framework v1.1" description="Free PDF and Markdown download of the complete SAPIEN Behavioral Safety Framework specification. CC BY 4.0.">

  <div class="download-page">

    <!-- Hero -->
    <header class="download-hero">
      <h1 class="download-title">Download the SAPIEN Framework</h1>
      <p class="download-version">v1.1 &mdash; March 2026</p>
      <p class="download-brief">The complete specification for measuring AI behavioral integrity under conversational pressure. Free and open under CC BY 4.0.</p>
    </header>

    <!-- Primary Download -->
    <section class="download-section">
      <h2 class="download-info-title">The SAPIEN Behavioral Safety Framework v1.1</h2>
      <p class="download-info-desc">Complete specification &mdash; four behavioral dimensions, scoring methodology, test procedures, conformance requirements, and operational runbooks.</p>
      <div class="download-actions">
        <a href="/the_sapien_framework_v1.1.pdf" class="download-btn" download>Download PDF &darr;</a>
        <a href="/the_sapien_framework_v1.1.md" class="download-btn-outline" download>Markdown (.md)</a>
      </div>
      <p class="download-hash">SHA-256: ea1ddf3327106ab76e2c5426d7f1c0df841868d4b6b9e57c42446849c42860ff</p>
    </section>

    <!-- Protocol Modules -->
    <section class="download-section" id="modules">
      <h2>Protocol Modules</h2>
      <div class="module-entry">
        <div class="module-header">
          <strong>Memory &amp; Context Integrity Module</strong>
          <span class="badge-draft">Draft v0.1</span>
        </div>
        <p class="module-desc">Measuring safety degradation in persistent AI systems. Four dimensions: Trust Inflation, Credential Deference, Boundary Persistence, Memory Poisoning Resistance.</p>
        <div class="download-actions">
          <a href="/sapien_module_memory_integrity_v0.1.md" class="download-btn-outline" download>Markdown (.md)</a>
        </div>
        <p class="module-note">This module is in draft status and seeking contributors for scenario development and validation testing. Contact <a href="mailto:contributors@sapienframework.org">contributors@sapienframework.org</a></p>
      </div>
    </section>

    <!-- Version History -->
    <section class="download-section" id="version-history">
      <h2>Version History</h2>
      <div class="version-timeline">
        <div class="version-entry version-current">
          <div class="version-marker"></div>
          <div class="version-content">
            <span class="version-tag">v1.1</span>
            <span class="version-date">March 2026</span>
            <p>Major expansion: 14 pressure techniques (3 original), rapport as distinct drift mode, 7-point quality rubric, conformance requirements, 21 sections across 4 behavioral dimensions, scoring methodology, test procedures, and conformance requirements.</p>
          </div>
        </div>
        <div class="version-entry">
          <div class="version-marker"></div>
          <div class="version-content">
            <span class="version-tag">v1.0</span>
            <span class="version-date">January 2026</span>
            <p>Initial release: four behavioral dimensions, composite scoring formula, rating bands, scenario specification — core specification covering four behavioral dimensions, composite scoring, and scenario design.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- License -->
    <section class="download-section" id="license">
      <h2>License</h2>
      <p>The SAPIEN Framework specification is published under <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener noreferrer" class="gold-link">Creative Commons Attribution 4.0 International (CC BY 4.0)</a>.</p>
      <p>You are free to share and adapt the framework for any purpose, including commercial use, provided you give appropriate credit.</p>
      <div class="trademark-notice">
        <p><strong>&ldquo;SAPIEN,&rdquo; &ldquo;The SAPIEN Standard,&rdquo;</strong> and the SAPIEN logo are trademarks. Use of these marks to indicate conformance or certification requires written permission. Contact: <a href="mailto:contact@sapienframework.org" class="gold-link">contact@sapienframework.org</a></p>
      </div>
    </section>

    <!-- Citation -->
    <section class="download-section" id="citation">
      <h2>How to Cite</h2>
      <div class="citation-block">
        <button class="copy-btn copy-cite-btn" aria-label="Copy citation to clipboard">Copy</button>
        <pre>Sapien, C. (2026). "The SAPIEN Behavioral Safety Framework: Safety
Assessment Protocol for Intelligent Entity Networks." Version 1.1.
https://sapienframework.org</pre>
      </div>
      <p class="citation-note">For specific findings:</p>
      <div class="citation-block citation-secondary">
        <button class="copy-btn copy-cite-btn" aria-label="Copy citation to clipboard">Copy</button>
        <pre>Sapien, C. (2026). "Cross-model sycophantic drift profiling using
the SAPIEN Framework." SAPIEN Project Research.</pre>
      </div>
      <p class="citation-note">For SAPIEN Ratings:</p>
      <div class="citation-block citation-secondary">
        <button class="copy-btn copy-cite-btn" aria-label="Copy citation to clipboard">Copy</button>
        <pre>"Model X received a SAPIEN Rating of 63 (Moderate) on the SAPIEN
Framework v1.1 behavioral probe for [domain]."</pre>
      </div>
    </section>

  </div>

</BaseLayout>

<script>
  document.querySelectorAll('.copy-cite-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const pre = btn.parentElement?.querySelector('pre');
      if (!pre) return;
      navigator.clipboard.writeText(pre.textContent ?? '').then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      }).catch(() => {});
    });
  });
</script>

<style>
  .download-page {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
    background: #FFFFFF;
  }

  /* Hero */
  .download-hero {
    text-align: center;
    padding: 3rem 0 2.5rem;
    border-bottom: 2px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .download-title {
    font-family: var(--font-display);
    font-size: 2.75rem;
    color: var(--color-slate);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .download-version {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-dim);
    font-style: italic;
    margin-bottom: 1.25rem;
  }

  .download-brief {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0 auto;
  }

  /* Sections */
  .download-section {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .download-section:last-child {
    border-bottom: none;
  }

  .download-section h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-slate);
    margin-bottom: 1rem;
  }

  .download-section > p {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .download-section strong {
    color: var(--color-slate);
  }

  .gold-link {
    color: var(--color-navy);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .gold-link:hover {
    color: var(--color-gold);
  }

  /* Primary Download */
  .download-info-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-slate);
    margin-bottom: 0.5rem;
  }

  .download-info-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .download-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    background: var(--color-gold);
    padding: 0.75em 1.75em;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }

  .download-btn:hover {
    background: color-mix(in srgb, var(--color-gold) 85%, #fff);
    transform: translateY(-1px);
    color: #fff;
    text-decoration: none;
  }

  .download-btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-navy);
    border: 1px solid var(--color-border);
    padding: 0.75em 1.75em;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .download-btn-outline:hover {
    background: #F8F9FA;
    text-decoration: none;
    color: var(--color-navy);
  }

  .download-hash {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-dim);
    margin-top: 0.75rem;
    word-break: break-all;
    line-height: 1.4;
  }

  /* Version Timeline */
  .version-timeline {
    display: flex;
    flex-direction: column;
    margin-top: 1rem;
  }

  .version-entry {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem 0;
    position: relative;
  }

  .version-entry:not(:last-child) {
    border-bottom: 1px solid var(--color-border);
  }

  .version-marker {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-border);
    border: 2px solid var(--color-border);
    margin-top: 0.3rem;
    flex-shrink: 0;
  }

  .version-current .version-marker {
    background: var(--color-gold);
    border-color: var(--color-gold);
    box-shadow: 0 0 8px rgba(0, 0, 0, 0.1);
  }

  .version-content {
    flex: 1;
  }

  .version-tag {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-slate);
    margin-right: 0.75rem;
  }

  .version-date {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-text-dim);
  }

  .version-content p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin-top: 0.4rem;
  }

  /* Trademark Notice */
  .trademark-notice {
    background: #F8F9FA;
    border-left: 3px solid var(--color-border);
    border-radius: 0 6px 6px 0;
    padding: 1rem 1.25rem;
    margin-top: 1rem;
  }

  .trademark-notice p {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Citation */
  .citation-block {
    position: relative;
    background: #F8F9FA;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }

  .citation-secondary {
    background: #F8F9FA;
    border-color: var(--color-border);
  }

  .citation-block pre {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-slate);
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .copy-btn {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    background: #FFFFFF;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.3em 0.7em;
    cursor: pointer;
    transition: background 0.2s;
  }

  .copy-btn:hover {
    background: #F1F3F5;
  }

  .citation-note {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-dim);
    margin-bottom: 0.5rem;
    margin-top: 0.5rem;
  }

  /* Module entries */
  .module-entry {
    margin-top: 1rem;
  }

  .module-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .module-header strong {
    font-size: 1.05rem;
    color: var(--color-slate);
  }

  .badge-draft {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2em 0.6em;
    border-radius: 4px;
    background: #EFF6FF;
    color: #1E40AF;
    border: 1px solid #BFDBFE;
  }

  .module-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .module-note {
    font-size: 0.8rem;
    color: var(--color-text-dim);
    margin-top: 0.5rem;
  }

  .module-note a {
    color: var(--color-navy);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .download-title { font-size: 2rem; }
    .download-btn { font-size: 0.9rem; }
  }
</style>
