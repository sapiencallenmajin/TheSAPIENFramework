---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-col footer-brand-col">
      <a href="/" class="footer-logo">
        <img src="/logos/logo_sapien.svg" alt="SAPIEN" class="footer-logo-img" />
        <span class="footer-brand">SAPIEN Framework</span>
      </a>
      <p class="footer-tagline">An open behavioral safety standard for AI systems.</p>
      <p class="footer-version">v1.1 &middot; March 2026 &middot; CC BY 4.0</p>
      <p class="footer-copy">&copy; {year} The SAPIEN Framework Project.</p>
    </div>
    <div class="footer-col">
      <h4 class="footer-heading">Navigate</h4>
      <nav class="footer-nav">
        <a href="/landscape">Landscape</a>
        <a href="/modules">Modules</a>
        <a href="/research">Research</a>
        <a href="/download">Download</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
      </nav>
    </div>
    <div class="footer-col">
      <h4 class="footer-heading">Resources</h4>
      <nav class="footer-nav">
        <a href="https://github.com/sapiencallenmajin/TheSAPIENFramework" target="_blank" rel="noopener noreferrer">GitHub &nearr;</a>
        <a href="/download">PDF Specification</a>
        <a href="/framework/scenarios">Scenario Standard</a>
        <a href="/framework/scoring">Scoring Methodology</a>
        <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener noreferrer">CC BY 4.0 License &nearr;</a>
      </nav>
    </div>
    <div class="footer-col">
      <h4 class="footer-heading">Community</h4>
      <nav class="footer-nav">
        <a href="https://github.com/sapiencallenmajin/TheSAPIENFramework/issues" target="_blank" rel="noopener noreferrer">Contribute &nearr;</a>
        <a href="mailto:contact@sapienframework.org">contact@sapienframework.org</a>
        <a href="mailto:contributors@sapienframework.org">contributors@sapienframework.org</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #1A1F2E;
    color: #F5F1EB;
    padding: 3.5rem 0 2.5rem;
    margin-top: 4rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    margin-bottom: 0.75rem;
  }
  .footer-logo:hover { text-decoration: none; }
  .footer-logo-img {
    height: 24px;
    width: auto;
    filter: brightness(0) invert(1) opacity(0.7);
  }
  .footer-brand {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-gold);
  }
  .footer-tagline {
    font-size: 0.85rem;
    color: #9CA3AF;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }
  .footer-version {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #6B7280;
    margin-bottom: 0.35rem;
  }
  .footer-copy {
    font-size: 0.75rem;
    color: #6B7280;
  }
  .footer-heading {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6B7280;
    margin-bottom: 0.75rem;
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer-nav a {
    font-size: 0.85rem;
    color: #9CA3AF;
    text-decoration: none;
    line-height: 1.4;
  }
  .footer-nav a:hover {
    color: #FFFFFF;
  }
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand-col {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
