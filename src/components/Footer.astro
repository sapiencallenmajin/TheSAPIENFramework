---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <p class="footer-brand">SAPIEN Framework</p>
      <p class="footer-tagline">An open behavioral safety standard for AI systems.</p>
      <p class="footer-version">SAPIEN Framework v1.1 · March 2026 · CC BY 4.0</p>
      <p class="footer-copy">&copy; {year} The SAPIEN Framework Project.</p>
      <p class="footer-contact">Contact: <a href="mailto:contact@sapienframework.org">contact@sapienframework.org</a></p>
    </div>
    <div class="footer-right">
      <nav class="footer-nav">
        <a href="/framework">Framework</a>
        <a href="/methodology">Methodology</a>
        <a href="/research">Research</a>
        <a href="/download">Download</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 3rem 0;
    margin-top: 4rem;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .footer-left {
    flex: 2;
    min-width: 280px;
  }
  .footer-right {
    flex: 1;
    min-width: 140px;
  }
  .footer-brand {
    font-weight: 700;
    color: var(--color-gold);
    margin-bottom: 0.25rem;
  }
  .footer-tagline {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .footer-version {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    margin-bottom: 0.5rem;
  }
  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-dim);
  }
  .footer-contact {
    font-size: 0.8rem;
    color: var(--color-text-dim);
    margin-top: 0.25rem;
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer-nav a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .footer-nav a:hover {
    color: #fff;
  }
  @media (max-width: 640px) {
    .footer-inner { flex-direction: column; }
  }
</style>
