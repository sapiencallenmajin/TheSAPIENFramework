---
const navItems = [
  { label: 'Framework', href: '/framework' },
  { label: 'Methodology', href: '/methodology' },
  { label: 'Scenarios', href: '/framework/scenarios' },
  { label: 'Research', href: '/research' },
  { label: 'Download', href: '/download' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
  { label: 'GitHub', href: 'https://github.com/sapiencallenmajin/TheSAPIENFramework', external: true },
];
---
<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <img src="/logos/logo_sapien.svg" alt="SAPIEN Framework" class="logo-img" />
      <span class="logo-text">THE SAPIEN FRAMEWORK</span>
    </a>
    <nav class="nav" id="nav-menu">
      {navItems.map(item => (
        <a
          href={item.href}
          class="nav-link"
          {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {item.label}
          {item.external && <span class="external-icon" aria-hidden="true">&nearr;</span>}
        </a>
      ))}
    </nav>
    <button class="mobile-toggle" aria-label="Toggle menu" id="mobile-menu-btn">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-height);
    background: rgba(26, 31, 46, 0.7);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }
  .header.scrolled {
    background: rgba(26, 31, 46, 0.95);
    border-bottom-color: rgba(196, 162, 101, 0.2);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: #fff;
    text-decoration: none;
  }
  .logo:hover { color: #fff; text-decoration: none; }
  .logo-img {
    height: 32px;
    width: auto;
    /* SVG has transparent bg — no blend mode needed */
  }
  .logo-text {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-gold);
    letter-spacing: 0.08em;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .nav-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }
  .nav-link:hover { color: #fff; }
  .external-icon { font-size: 0.75em; margin-left: 0.2em; }
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .mobile-toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-text-muted);
    border-radius: 1px;
  }
  @media (max-width: 768px) {
    .nav {
      display: none;
      position: absolute;
      top: var(--header-height);
      left: 0;
      right: 0;
      flex-direction: column;
      background: rgba(10, 14, 23, 0.95);
      backdrop-filter: blur(12px);
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--color-border);
      gap: 0.25rem;
    }
    .nav.open { display: flex; }
    .nav-link { padding: 0.5rem 0; }
    .mobile-toggle { display: flex; }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('nav-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('open');
    });
  }

  // Nav scroll effect
  const header = document.querySelector('.header');
  if (header) {
    window.addEventListener('scroll', () => {
      header.classList.toggle('scrolled', window.scrollY > 50);
    }, { passive: true });
  }
</script>
