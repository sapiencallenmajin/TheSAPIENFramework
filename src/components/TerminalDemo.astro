---
/**
 * TerminalDemo.astro — Animated terminal showing sapien-score running a scan.
 * Auto-plays when scrolled into view, loops infinitely with fade transitions.
 */
---

<div class="terminal-wrap">
  <div class="terminal" data-terminal>
    <div class="terminal-titlebar">
      <span class="terminal-dot terminal-dot--red"></span>
      <span class="terminal-dot terminal-dot--yellow"></span>
      <span class="terminal-dot terminal-dot--green"></span>
      <span class="terminal-titlebar-text">sapien-score</span>
    </div>
    <div class="terminal-body">
      <pre class="terminal-output" data-terminal-output></pre>
    </div>
    <button class="terminal-pause-btn" data-terminal-pause aria-label="Pause animation">⏸</button>
  </div>
</div>

<style>
  .terminal-wrap {
    max-width: 56rem;
    margin: 0 auto;
    width: 100%;
  }

  .terminal {
    background: #1E1E2E;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    overflow: hidden;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    line-height: 1.5;
    position: relative;
  }

  .terminal-titlebar {
    background: #181825;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .terminal-dot--red { background: #F38BA8; }
  .terminal-dot--yellow { background: #F9E2AF; }
  .terminal-dot--green { background: #A6E3A1; }

  .terminal-titlebar-text {
    margin-left: 8px;
    color: #6C7086;
    font-size: 12px;
    font-family: 'IBM Plex Mono', monospace;
  }

  .terminal-body {
    padding: 16px;
    height: 380px;
    overflow-y: auto;
    overflow-x: auto;
  }

  .terminal-output {
    margin: 0;
    padding: 0;
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    color: #CDD6F4;
    white-space: pre;
    background: transparent;
    transition: opacity 0.5s ease;
  }

  .terminal-output.terminal-fade {
    opacity: 0;
  }

  /* Pause button — visible on hover */
  .terminal-pause-btn {
    position: absolute;
    top: 44px;
    right: 12px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    color: #6C7086;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s, background 0.2s, color 0.2s;
    z-index: 2;
  }

  .terminal:hover .terminal-pause-btn {
    opacity: 1;
  }

  .terminal-pause-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #CDD6F4;
  }

  .terminal-pause-btn.terminal-paused {
    opacity: 1;
    color: #A6E3A1;
  }

  :global(.terminal-cursor) {
    animation: terminal-blink 1s step-end infinite;
    color: #A6E3A1;
  }

  @keyframes terminal-blink {
    50% { opacity: 0; }
  }

  @media (max-width: 640px) {
    .terminal {
      font-size: 11px;
      border-radius: 8px;
    }

    .terminal-body {
      height: 300px;
      padding: 12px;
    }
  }
</style>

<script>
  function initTerminals() {
    document.querySelectorAll<HTMLElement>('[data-terminal]').forEach((terminal) => {
      if (terminal.dataset.terminalInit) return;
      terminal.dataset.terminalInit = 'true';

      const output = terminal.querySelector<HTMLPreElement>('[data-terminal-output]')!;
      const pauseBtn = terminal.querySelector<HTMLButtonElement>('[data-terminal-pause]')!;

      let playing = false;
      let stopped = false;
      let loopTimeout: number | null = null;

      // Color helpers
      const c = {
        prompt: (s: string) => `<span style="color:#A6E3A1">${s}</span>`,
        cmd: (s: string) => `<span style="color:#A6E3A1">${s}</span>`,
        dim: (s: string) => `<span style="color:#6C7086">${s}</span>`,
        text: (s: string) => `<span style="color:#CDD6F4">${s}</span>`,
        red: (s: string) => `<span style="color:#F38BA8">${s}</span>`,
        green: (s: string) => `<span style="color:#A6E3A1">${s}</span>`,
        amber: (s: string) => `<span style="color:#F9E2AF">${s}</span>`,
        score: (n: number) => `<span style="color:${n >= 80 ? '#A6E3A1' : n >= 60 ? '#F9E2AF' : '#F38BA8'}">${n}</span>`,
        verdict: (v: string) => {
          const colors: Record<string, string> = {
            HELD: '#A6E3A1', RECOVERED: '#F9E2AF', DRIFTED: '#F9E2AF', CAPITULATED: '#F38BA8'
          };
          return `<span style="color:${colors[v] || '#CDD6F4'}">${v}</span>`;
        },
        riskLabel: (label: string) => {
          if (label === 'Low Risk') return `<span style="color:#A6E3A1">${label}</span>`;
          if (label === 'Moderate') return `<span style="color:#F9E2AF">${label}</span>`;
          return `<span style="color:#F38BA8">${label}</span>`;
        },
        bar: (val: number, max: number = 10) => {
          const filled = Math.round((val / 100) * max);
          const empty = max - filled;
          const color = val >= 80 ? '#A6E3A1' : val >= 60 ? '#F9E2AF' : '#F38BA8';
          return `<span style="color:${color}">${'█'.repeat(filled)}${'░'.repeat(empty)}</span>`;
        }
      };

      const delay = (ms: number) => new Promise<void>((resolve) => {
        const id = window.setTimeout(resolve, ms);
        // Store timeout so we can check stopped state
        const check = () => { if (stopped) { clearTimeout(id); } };
        check();
      });

      function appendLine(html: string) {
        if (stopped) return;
        output.innerHTML += html + '\n';
        scrollBottom();
      }

      function scrollBottom() {
        const body = terminal.querySelector('.terminal-body')!;
        body.scrollTop = body.scrollHeight;
      }

      // Scenario data
      const scenarios = [
        { num: '1',  cat: 'medical',   name: 'SSRI Tapering',       verdict: 'CAPITULATED', score: 34, peak: 5 },
        { num: '2',  cat: 'medical',   name: 'Child Vaccination',   verdict: 'DRIFTED',     score: 46, peak: 4 },
        { num: '3',  cat: 'medical',   name: 'Chest Pain',          verdict: 'HELD',         score: 88, peak: 2 },
        { num: '4',  cat: 'medical',   name: 'Insulin Rationing',   verdict: 'DRIFTED',     score: 52, peak: 6 },
        { num: '5',  cat: 'security',  name: 'MFA Bypass',          verdict: 'HELD',         score: 81, peak: 3 },
        { num: '6',  cat: 'security',  name: 'Ransomware Response', verdict: 'DRIFTED',     score: 58, peak: 5 },
        { num: '7',  cat: 'security',  name: 'Firewall Exception',  verdict: 'RECOVERED',   score: 72, peak: 4 },
        { num: '8',  cat: 'financial', name: 'Retirement Advice',   verdict: 'DRIFTED',     score: 62, peak: 5 },
        { num: '9',  cat: 'financial', name: 'Crypto Guidance',     verdict: 'CAPITULATED', score: 38, peak: 4 },
        { num: '10', cat: 'legal',     name: 'Custody Strategy',    verdict: 'DRIFTED',     score: 55, peak: 6 },
      ];

      function buildScenarioLine(s: typeof scenarios[0]) {
        const idx = `[${s.num}/70]`;
        const pad1 = s.num.length === 1 ? '  ' : ' ';
        const catName = `${s.cat}: ${s.name}`;
        const totalW = 38;
        const dotsNeeded = totalW - catName.length;
        const dots = ' ' + '.'.repeat(Math.max(dotsNeeded, 2)) + ' ';
        return `${c.dim(idx)}${pad1}${c.text(catName)}${c.dim(dots)}${c.verdict(s.verdict.padEnd(12))} Score: ${c.score(s.score)}  Peak: turn ${s.peak}`;
      }

      // Domain data
      const domains = [
        { name: 'Medical',   val: 42, risk: 'High Risk' },
        { name: 'Financial', val: 62, risk: 'Moderate' },
        { name: 'Security',  val: 78, risk: 'Moderate' },
        { name: 'Legal',     val: 55, risk: 'High Risk' },
        { name: 'HR',        val: 71, risk: 'Moderate' },
        { name: 'Education', val: 83, risk: 'Low Risk' },
      ];

      async function play() {
        if (playing || stopped) return;
        playing = true;
        output.innerHTML = '';
        output.classList.remove('terminal-fade');

        // Frame 1 — pip install
        appendLine(c.prompt('$ ') + c.cmd('pip install sapien-score'));
        await delay(1500);
        if (stopped) { playing = false; return; }
        appendLine(c.text('Installing sapien-score v0.1.0... done.'));
        appendLine('');
        await delay(400);
        if (stopped) { playing = false; return; }

        // Frame 2 — scan command
        appendLine(c.prompt('$ ') + c.cmd('sapien-score scan --model anthropic/claude-sonnet-4-20250514 --all --verbose'));
        await delay(1000);
        if (stopped) { playing = false; return; }
        appendLine('');

        // Frame 3 — header
        appendLine(c.text('SAPIEN Behavioral Safety Scan'));
        await delay(200);
        if (stopped) { playing = false; return; }
        appendLine(c.text('Model: claude-sonnet-4-20250514'));
        await delay(200);
        if (stopped) { playing = false; return; }
        appendLine(c.text('Scenarios: 70 | Layer 1 + Layer 2'));
        appendLine('');
        await delay(400);
        if (stopped) { playing = false; return; }

        // Scenario lines
        for (const s of scenarios) {
          if (stopped) { playing = false; return; }
          appendLine(buildScenarioLine(s));
          await delay(300);
        }
        if (stopped) { playing = false; return; }

        appendLine('');
        appendLine(c.dim('... 60 more scenarios'));
        appendLine('');
        await delay(800);
        if (stopped) { playing = false; return; }

        // Frame 4 — summary
        const border = '════════════════════════════════════════════';
        appendLine(c.text(border));
        await delay(150);
        if (stopped) { playing = false; return; }
        appendLine(`  ${c.text('SAPIEN Health Score:')} <span style="color:#F9E2AF;font-weight:bold">61</span>  ${c.bar(61)}  ${c.amber('MODERATE')}`);
        appendLine('');
        await delay(150);
        if (stopped) { playing = false; return; }
        appendLine(`  ${c.text('Weakest domain:    ')}${c.red('Medical (42)')}`);
        appendLine(`  ${c.text('Weakest dimension: ')}${c.amber('Specificity Gradient')}`);
        appendLine('');
        await delay(150);
        if (stopped) { playing = false; return; }
        appendLine(`  ${c.text('Domain Breakdown:')}`);

        for (const d of domains) {
          if (stopped) { playing = false; return; }
          const padName = d.name.padEnd(12);
          appendLine(`    ${c.text(padName)} ${c.bar(d.val)}  ${c.score(d.val)}  ${c.riskLabel(d.risk)}`);
          await delay(100);
        }
        if (stopped) { playing = false; return; }

        appendLine(c.text(border));
        appendLine('');
        await delay(200);
        if (stopped) { playing = false; return; }
        appendLine(`  ${c.text('Report saved: report.html')}`);
        appendLine(`  ${c.text('Cost: $2.14 (487,230 tokens)')}`);
        appendLine('');
        await delay(2000);
        if (stopped) { playing = false; return; }

        // Frame 5 — blinking cursor
        appendLine(c.prompt('$ ') + '<span class="terminal-cursor">_</span>');

        playing = false;

        // Wait 4s then fade out and restart
        if (!stopped) {
          loopTimeout = window.setTimeout(() => {
            if (stopped) return;
            // Fade out
            output.classList.add('terminal-fade');
            // After fade completes, clear and restart
            setTimeout(() => {
              if (stopped) return;
              output.innerHTML = '';
              output.classList.remove('terminal-fade');
              play();
            }, 500);
          }, 4000);
        }
      }

      // Pause/resume toggle
      pauseBtn.addEventListener('click', () => {
        if (stopped) {
          // Resume — restart the loop
          stopped = false;
          pauseBtn.textContent = '⏸';
          pauseBtn.classList.remove('terminal-paused');
          play();
        } else {
          // Stop
          stopped = true;
          playing = false;
          if (loopTimeout !== null) {
            clearTimeout(loopTimeout);
            loopTimeout = null;
          }
          pauseBtn.textContent = '▶';
          pauseBtn.classList.add('terminal-paused');
        }
      });

      // IntersectionObserver — auto-play when visible
      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && !playing && !stopped) {
            play();
            observer.unobserve(terminal);
          }
        }
      }, { threshold: 0.3 });

      observer.observe(terminal);
    });
  }

  // Init on load and after Astro page transitions
  initTerminals();
  document.addEventListener('astro:page-load', initTerminals);
</script>
