---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <div class="learn-page">
    <div class="learn-banner">
      This is a plain-language guide. For the technical framework, visit the <a href="/modules/">Modules page</a>.
    </div>
    <slot />
  </div>
</BaseLayout>

<style>
  .learn-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .learn-banner {
    margin-top: 1.5rem;
    padding: 0.75rem 1rem;
    background: #F8F9FA;
    border: 1px solid #E2E8F0;
    border-radius: 6px;
    font-size: 0.85rem;
    color: #4A5568;
    line-height: 1.5;
  }
  .learn-banner a {
    color: var(--color-navy);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .learn-banner a:hover {
    color: var(--color-gold);
  }
</style>

<style is:global>
  .learn-hero {
    padding: 3rem 0 2rem;
  }
  .learn-hero h1 {
    font-family: var(--font-display);
    font-size: 2.25rem;
    color: var(--color-slate);
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .learn-hero .hero-subtitle {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
  .learn-body {
    padding-bottom: 3rem;
  }
  .learn-section {
    padding: 2rem 0;
  }
  .learn-section h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-slate);
    margin-bottom: 1.25rem;
    line-height: 1.3;
  }
  .learn-section p {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }
  .learn-section p:last-child {
    margin-bottom: 0;
  }
  .learn-page .section-divider {
    border: none;
    border-top: 1px solid #E2E8F0;
    margin: 0;
  }
  .learn-links {
    padding: 2.5rem 0;
  }
  .learn-links h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-slate);
    margin-bottom: 1.25rem;
  }
  .learn-link {
    display: block;
    padding: 0.75rem 0;
    font-size: 1.125rem;
    color: var(--color-navy);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }
  .learn-link:hover {
    color: var(--color-gold);
  }
  .learn-link-alt {
    margin-top: 0.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid #E2E8F0;
    font-size: 1rem;
    color: var(--color-text-muted);
  }
  .learn-link-alt:hover {
    color: var(--color-gold);
  }
  @media (max-width: 768px) {
    .learn-hero h1 {
      font-size: 1.75rem;
    }
    .learn-hero .hero-subtitle {
      font-size: 1.05rem;
    }
    .learn-section p {
      font-size: 1.05rem;
    }
  }
</style>
