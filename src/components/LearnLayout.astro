---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <div class="learn-page">
    <div class="learn-banner-wrap">
      <div class="learn-banner">
        This is a plain-language guide. For the technical framework, visit the <a href="/modules/">Modules page</a>.
      </div>
    </div>
    <slot />
  </div>
</BaseLayout>

<style>
  .learn-page {
    /* No max-width — full-width sections are handled by children */
  }
  .learn-banner-wrap {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .learn-banner {
    margin-top: 1.5rem;
    padding: 0.75rem 1rem;
    background: #F8F9FA;
    border: 1px solid #E2E8F0;
    border-radius: 6px;
    font-size: 0.85rem;
    color: #4A5568;
    line-height: 1.5;
  }
  .learn-banner a {
    color: var(--color-navy);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .learn-banner a:hover {
    color: var(--color-gold);
  }
</style>

<style is:global>
  /* Shared utilities for Learn pages */
  .learn-contain {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .learn-contain-narrow {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .learn-band {
    padding: 5rem 0;
  }
  .learn-band-gray {
    background: #F8F9FA;
  }
  .learn-band-dark {
    background: var(--color-slate);
    color: #F5F1EB;
  }
  .learn-body-text {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text);
  }
  .learn-body-text p {
    margin-bottom: 1.25rem;
  }
  .learn-body-text p:last-child {
    margin-bottom: 0;
  }
  .learn-band-dark .learn-body-text {
    color: #CBD5E1;
  }
  .learn-h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-slate);
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }
  .learn-band-dark .learn-h2 {
    color: #FFFFFF;
  }

  /* Shared hero with background image */
  .learn-hero-img {
    position: relative;
    padding: 6rem 1.5rem;
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }
  .learn-hero-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.88);
  }
  .learn-hero-img .hero-inner {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
  }
  .learn-hero-img h1 {
    font-family: var(--font-display);
    font-size: 2.75rem;
    color: #FFFFFF;
    margin-bottom: 1rem;
    line-height: 1.15;
  }
  .learn-hero-img .hero-sub {
    font-size: 1.25rem;
    color: #CBD5E1;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .learn-hero-img .hero-cta {
    display: inline-block;
    padding: 0.75rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-slate);
    background: var(--color-gold);
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .learn-hero-img .hero-cta:hover {
    background: #D4B275;
    transform: translateY(-1px);
  }

  /* Shared link cards for CTA sections */
  .learn-card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .learn-card-link {
    display: block;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .learn-card-link:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--color-gold);
  }
  .learn-card-link h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: #FFFFFF;
    margin-bottom: 0.5rem;
  }
  .learn-card-link p {
    font-size: 0.9rem;
    color: #94A3B8;
    line-height: 1.5;
    margin: 0;
  }
  .learn-tech-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.95rem;
    color: var(--color-gold);
    text-decoration: none;
    font-weight: 500;
  }
  .learn-tech-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 768px) {
    .learn-hero-img {
      padding: 4rem 1.5rem;
    }
    .learn-hero-img h1 {
      font-size: 2rem;
    }
    .learn-hero-img .hero-sub {
      font-size: 1.05rem;
    }
    .learn-band {
      padding: 3rem 0;
    }
    .learn-card-grid {
      grid-template-columns: 1fr;
    }
    .learn-h2 {
      font-size: 1.4rem;
    }
  }
</style>
