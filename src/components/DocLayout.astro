---
import BaseLayout from '../layouts/BaseLayout.astro';

interface SidebarChild {
  label: string;
  anchor: string;
}

interface SidebarItem {
  label: string;
  anchor: string;
  children?: SidebarChild[];
}

interface Props {
  title: string;
  description: string;
  sidebarItems: SidebarItem[];
}

const { title, description, sidebarItems } = Astro.props;
---
<BaseLayout title={title} description={description}>

  <!-- Mobile TOC -->
  <div class="mobile-toc" id="mobile-toc">
    <button class="mobile-toc-toggle" id="mobile-toc-toggle" aria-expanded="false" aria-controls="mobile-toc-list">
      Table of Contents
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="chevron"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <nav class="mobile-toc-list" id="mobile-toc-list" aria-hidden="true">
      {sidebarItems.map(item => (
        <>
          <a href={`#${item.anchor}`} class="toc-link toc-h1">{item.label}</a>
          {item.children?.map(child => (
            <a href={`#${child.anchor}`} class="toc-link toc-h2">{child.label}</a>
          ))}
        </>
      ))}
    </nav>
  </div>

  <div class="doc-layout">
    <!-- Desktop Sidebar -->
    <aside class="sidebar" id="sidebar">
      <nav class="sidebar-nav">
        {sidebarItems.map(item => (
          <div class="sidebar-section">
            <a href={`#${item.anchor}`} class="sidebar-link" data-section={item.anchor}>{item.label}</a>
            {item.children?.map(child => (
              <a href={`#${child.anchor}`} class="sidebar-sublink" data-section={child.anchor}>{child.label}</a>
            ))}
          </div>
        ))}
      </nav>
    </aside>

    <!-- Main Content -->
    <div class="content-area">
      <slot />
    </div>
  </div>

</BaseLayout>

<style is:global>
  /* ===== DocLayout shared styles ===== */

  .doc-layout {
    display: flex;
    max-width: 1600px;
    margin: 0 auto;
    min-height: 100vh;
  }

  /* Sidebar */
  .sidebar {
    width: 16rem;
    flex-shrink: 0;
    position: sticky;
    top: var(--header-height, 64px);
    height: calc(100vh - var(--header-height, 64px));
    overflow-y: auto;
    background: color-mix(in srgb, var(--color-slate) 100%, black 15%);
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.5rem 0;
    scrollbar-width: thin;
    scrollbar-color: var(--color-text-dim) transparent;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
  }

  .sidebar-section {
    padding-bottom: 0.25rem;
    margin-bottom: 0.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }
  .sidebar-section:last-child { border-bottom: none; }

  .sidebar-link,
  .sidebar-sublink {
    display: block;
    padding: 0.35rem 1.25rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-cream) 70%, transparent);
    text-decoration: none;
    border-left: 3px solid transparent;
    transition: all 0.15s ease;
    line-height: 1.4;
  }
  .sidebar-link { font-weight: 600; font-size: 0.875rem; }
  .sidebar-sublink { padding-left: 2rem; font-size: 0.8rem; }

  .sidebar-link:hover,
  .sidebar-sublink:hover {
    color: var(--color-cream);
    background: rgba(255, 255, 255, 0.04);
  }

  .sidebar-link.active,
  .sidebar-sublink.active {
    color: var(--color-gold);
    border-left-color: var(--color-gold);
    background: rgba(255, 255, 255, 0.04);
  }

  /* Content area */
  .content-area {
    flex: 1;
    min-width: 0;
    padding: 2rem 3rem 4rem;
    background: var(--color-slate);
  }

  /* Scroll margin for anchor links behind sticky header */
  .content-area [id] {
    scroll-margin-top: calc(var(--header-height, 64px) + 1.5rem);
  }

  /* Spec header */
  .spec-header {
    text-align: center;
    padding-bottom: 2.5rem;
    margin-bottom: 2.5rem;
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
  }

  .spec-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.35em 1em;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #9CA3AF;
    border-radius: 9999px;
    margin-bottom: 1rem;
  }

  .spec-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--color-cream);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .spec-subtitle {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: var(--color-cream);
    margin-bottom: 1rem;
    font-style: italic;
  }

  .spec-meta {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-gray);
    margin-bottom: 0.25rem;
  }

  /* Sections */
  .spec-section {
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .section-heading h2 {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-cream);
    margin: 0;
  }

  /* Badges */
  .badge-normative,
  .badge-informative {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25em 0.75em;
    border-radius: 4px;
  }
  .badge-normative { background: #475569; color: #fff; }
  .badge-informative { background: #57534e; color: #fff; }

  /* Subsections */
  .spec-subsection {
    margin-top: 2rem;
    padding-top: 1.5rem;
  }

  .spec-subsection h3 {
    font-family: var(--font-body);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-cream);
    margin-bottom: 1rem;
  }

  /* Typography */
  .content-area p {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: color-mix(in srgb, var(--color-cream) 80%, transparent);
    margin-bottom: 1rem;
  }

  .content-area h4 {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-cream);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .content-area ul,
  .content-area ol {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: color-mix(in srgb, var(--color-cream) 80%, transparent);
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .content-area li { margin-bottom: 0.35rem; }
  .content-area strong { color: var(--color-cream); }

  .content-area code {
    font-size: 0.875em;
    background: color-mix(in srgb, var(--color-navy) 50%, transparent);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--color-gold);
  }

  .content-area blockquote {
    border-left: 4px solid var(--color-gold);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    background: color-mix(in srgb, var(--color-navy) 30%, transparent);
    border-radius: 0 8px 8px 0;
    font-size: 1.05rem;
    color: var(--color-cream);
    font-weight: 500;
    font-style: italic;
  }

  /* RFC 2119 keywords */
  .rfc { font-weight: 700; color: var(--color-gold); }

  /* Term lists */
  .term-list { margin: 1rem 0 1.5rem; }

  .term-list dt {
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--color-cream);
    margin-top: 1rem;
    font-size: 0.95rem;
  }

  .term-list dd {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-cream) 75%, transparent);
    margin-left: 0;
    padding-left: 1rem;
    border-left: 2px solid rgba(255, 255, 255, 0.08);
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
  }

  .field-type {
    font-family: monospace;
    font-size: 0.8em;
    color: var(--color-gray);
    font-weight: 400;
  }

  /* Preamble */
  .spec-preamble {
    padding-bottom: 2rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* Rubric note */
  .rubric-note {
    font-size: 0.9rem !important;
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, var(--color-navy) 40%, transparent);
    border-radius: 6px;
    border-left: 3px solid var(--color-gold);
    margin-top: 1rem;
  }

  /* Mobile TOC */
  .mobile-toc {
    display: none;
    position: sticky;
    top: var(--header-height, 64px);
    z-index: 40;
    background: color-mix(in srgb, var(--color-slate) 100%, black 15%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .mobile-toc-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1rem 1.5rem;
    background: none;
    border: none;
    color: var(--color-gold);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
  }

  .mobile-toc-toggle .chevron { transition: transform 0.2s; }
  .mobile-toc-toggle[aria-expanded="true"] .chevron { transform: rotate(180deg); }

  .mobile-toc-list {
    display: none;
    max-height: 60vh;
    overflow-y: auto;
    padding: 0 1rem 1rem;
  }
  .mobile-toc-list[aria-hidden="false"] { display: block; }

  .toc-link {
    display: block;
    padding: 0.4rem 0.75rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-cream) 70%, transparent);
    text-decoration: none;
    border-radius: 4px;
  }
  .toc-link:hover {
    color: var(--color-cream);
    background: rgba(255, 255, 255, 0.04);
  }
  .toc-h2 { padding-left: 1.5rem; font-size: 0.8rem; }

  /* Prose line-length cap for readability */
  .content-area p,
  .content-area li,
  .content-area dd,
  .content-area blockquote {
    max-width: 80ch;
  }

  /* Visual elements go full width */
  .content-area .formula-box,
  .content-area .rating-bar,
  .content-area .rating-bands,
  .content-area .detection-flow,
  .content-area .procedure-grid,
  .content-area .profile-grid,
  .content-area .technique-grid,
  .content-area .conformance-grid,
  .content-area .maturity-grid,
  .content-area .results-table-wrap,
  .content-area .example-scenario,
  .content-area details {
    max-width: none;
  }

  /* Accordion section card styling — tight stacking like a technical index */
  details.framework-section > summary {
    background: rgba(255, 255, 255, 0.03);
    border-radius: 0;
    padding: 0.85rem 1.25rem;
    margin-bottom: 2px;
    transition: background 0.2s ease;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  details.framework-section > summary:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  details.framework-section[open] > summary {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 0;
    margin-bottom: 0;
    border-bottom: none;
  }

  /* Subsection card styling */
  details.framework-subsection > summary {
    background: rgba(255, 255, 255, 0.02);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.15rem;
    transition: background 0.2s ease;
  }

  details.framework-subsection > summary:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .sidebar { display: none; }
    .mobile-toc { display: block; }
    .content-area { padding: 1.5rem 1.25rem 3rem; }
    .spec-title { font-size: 1.75rem; }
    .section-heading h2 { font-size: 1.5rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sidebarLinks = document.querySelectorAll('[data-section]');
    const sections = new Map();

    sidebarLinks.forEach(link => {
      const id = link.getAttribute('data-section');
      const section = document.getElementById(id);
      if (section) sections.set(id, { el: section, link });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            sidebarLinks.forEach(l => l.classList.remove('active'));
            const id = entry.target.id;
            const data = sections.get(id);
            if (data) {
              data.link.classList.add('active');
              data.link.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
            }
          }
        });
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    );

    sections.forEach(({ el }) => observer.observe(el));

    // Mobile TOC toggle
    const toggle = document.getElementById('mobile-toc-toggle');
    const list = document.getElementById('mobile-toc-list');

    if (toggle && list) {
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        list.setAttribute('aria-hidden', String(expanded));
      });

      list.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          toggle.setAttribute('aria-expanded', 'false');
          list.setAttribute('aria-hidden', 'true');
        });
      });
    }
  });
</script>
