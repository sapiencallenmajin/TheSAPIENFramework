---
// Search overlay powered by Pagefind
---
<div class="search-overlay" id="search-overlay" aria-hidden="true">
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-modal">
    <div class="search-modal-header">
      <span class="search-modal-title">Search</span>
      <button class="search-close" id="search-close" aria-label="Close search">&times;</button>
    </div>
    <div id="search-container"></div>
  </div>
</div>

<style is:global>
  /* Search trigger in nav */
  .search-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.35rem 0.6rem;
    cursor: pointer;
    color: var(--color-text-dim);
    font-size: 0.8rem;
    gap: 0.4rem;
    transition: border-color 0.15s, color 0.15s;
  }

  .search-trigger:hover {
    border-color: var(--color-navy);
    color: var(--color-navy);
  }

  .search-trigger svg {
    width: 14px;
    height: 14px;
  }

  .search-trigger kbd {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0.1em 0.35em;
    color: var(--color-text-dim);
  }

  /* Overlay */
  .search-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
  }

  .search-overlay[aria-hidden="false"] {
    display: flex;
  }

  .search-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
  }

  .search-modal {
    position: relative;
    width: 90%;
    max-width: 640px;
    max-height: 70vh;
    background: #FFFFFF;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .search-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .search-modal-title {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-dim);
  }

  .search-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--color-text-dim);
    cursor: pointer;
    line-height: 1;
    padding: 0 0.25rem;
  }

  .search-close:hover {
    color: var(--color-slate);
  }

  #search-container {
    overflow-y: auto;
    padding: 0;
  }

  /* Pagefind UI overrides */
  .pagefind-ui {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--color-navy);
    --pagefind-ui-text: var(--color-text-muted);
    --pagefind-ui-background: #FFFFFF;
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-bg-alt);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: var(--font-body);
  }

  .pagefind-ui .pagefind-ui__search-input {
    font-family: var(--font-body);
    font-size: 1rem;
    border-radius: 0;
    border: none;
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 1rem;
  }

  .pagefind-ui .pagefind-ui__search-input:focus {
    outline: none;
    border-bottom-color: var(--color-gold);
  }

  .pagefind-ui .pagefind-ui__search-clear {
    top: 0.75rem;
    right: 1rem;
  }

  .pagefind-ui .pagefind-ui__results-area {
    padding: 0 1rem 1rem;
  }

  .pagefind-ui .pagefind-ui__result {
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: var(--color-navy);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .pagefind-ui .pagefind-ui__result-link:hover {
    color: var(--color-gold);
  }

  .pagefind-ui .pagefind-ui__result-excerpt {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .pagefind-ui mark {
    background: rgba(196, 162, 101, 0.2);
    color: var(--color-slate);
    padding: 0.05em 0.15em;
    border-radius: 2px;
  }

  .pagefind-ui .pagefind-ui__message {
    font-size: 0.85rem;
    color: var(--color-text-dim);
    padding: 1rem;
  }

  @media (max-width: 768px) {
    .search-overlay {
      padding-top: 0;
    }
    .search-modal {
      width: 100%;
      max-width: 100%;
      max-height: 100vh;
      border-radius: 0;
      height: 100vh;
    }
    .search-trigger kbd {
      display: none;
    }
  }
</style>

<script>
  // Search overlay controls
  const overlay = document.getElementById('search-overlay');
  const backdrop = document.getElementById('search-backdrop');
  const closeBtn = document.getElementById('search-close');

  let pagefindLoaded = false;

  function openSearch() {
    if (!overlay) return;
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    if (!pagefindLoaded) {
      pagefindLoaded = true;
      // Load Pagefind CSS
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(link);

      // Load Pagefind JS dynamically (avoids Vite resolution at build time)
      const script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = () => {
        new (window as any).PagefindUI({
          element: '#search-container',
          showSubResults: true,
          showImages: false,
        });
        setTimeout(() => {
          const input = document.querySelector('.pagefind-ui__search-input') as HTMLInputElement;
          if (input) input.focus();
        }, 100);
      };
      script.onerror = () => {
        const container = document.getElementById('search-container');
        if (container) container.innerHTML = '<p style="padding:1rem;color:var(--color-text-dim);">Search is available after building the site (npm run build).</p>';
      };
      document.head.appendChild(script);
    } else {
      setTimeout(() => {
        const input = document.querySelector('.pagefind-ui__search-input') as HTMLInputElement;
        if (input) { input.focus(); input.select(); }
      }, 50);
    }
  }

  function closeSearch() {
    if (!overlay) return;
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Event listeners
  if (backdrop) backdrop.addEventListener('click', closeSearch);
  if (closeBtn) closeBtn.addEventListener('click', closeSearch);

  // Keyboard shortcut: Ctrl/Cmd + K
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      const isOpen = overlay?.getAttribute('aria-hidden') === 'false';
      if (isOpen) closeSearch();
      else openSearch();
    }
    if (e.key === 'Escape' && overlay?.getAttribute('aria-hidden') === 'false') {
      closeSearch();
    }
  });

  // Global function for the nav button
  (window as any).__openSearch = openSearch;
</script>
